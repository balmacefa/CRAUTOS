# Database Configuration
DATABASE_URL=postgresql://crautos_user:crautos_pass@localhost: 5432/crautos_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crautos_db
DB_USER=crautos_user
DB_PASSWORD=crautos_pass

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
API_WORKERS=4

# Scraper Configuration
SCRAPER_HEADLESS=True
SCRAPER_MAX_PAGES=50
SCRAPER_DELAY_SECONDS=2
SCRAPER_TIMEOUT=30

# CRAutos URLs
CRAUTOS_BASE_URL=https://crautos.com
CRAUTOS_SEARCH_URL=https://crautos.com/autosusados/searchresults. cfm

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/crautos.log

# Scheduler
SCRAPER_SCHEDULE_HOUR=2
REPORT_SCHEDULE_HOUR=8